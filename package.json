{
  "name": "bookbackend",
  "version": "1.0.0",
  "description": "Book management backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "test:auth": "jest --runInBand test/test-auth-api.ts",
    "test:book": "jest --runInBand test/test-book-api.ts",
    "test:reading-log": "jest --runInBand test/test-reading-log-api.ts",
    "test:memo": "jest --runInBand test/test-memo-api.ts",
    "test:stats": "jest --runInBand test/test-stats-api.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-session": "^1.19.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
